@if (User.Identity?.IsAuthenticated ?? false)
{
    <a class="nav-link text-dark"
       asp-area="Identity"
       asp-page="/Account/Logout">
        Logout
    </a>
}
else
{
    <a class="nav-link text-dark"
       asp-area="Identity"
       asp-page="/Account/Login">
        Login
    </a>

    <a class="nav-link text-dark"
       asp-area="Identity"
       asp-page="/Account/Register">
        Register
    </a>
}